# -------------------------------------------------------------------------

FACTORY_DEF * RoutingFactory   FACTORY_NAME "Router and Unexpected Input Remover"   COMMAND_PARM_EVALUATION SINGLE_PASS   INPUT FEATURE_TYPE *    ROUTE ACAD ACAD_2::0 multi_reader_keyword,$(DATASET_KEYWORD_ACAD_2) TO FME_GENERIC ::0 ALIAS_GEOMETRY    ROUTE GEOTIFF GEOTIFF_1::GEOTIFF multi_reader_keyword,$(DATASET_KEYWORD_GEOTIFF_1) TO FME_GENERIC ::GEOTIFF ALIAS_GEOMETRY    MERGE_INPUT Yes   OUTPUT ROUTED FEATURE_TYPE *
ACAD_2_MERGE_DEF ACAD_2::0 GLOB * DEFLINE autocad_color,10,autocad_linetype,CONTINUOUS,autocad_layer_frozen,no,autocad_layer_hidden,no,autocad_layer_locked,no,autocad_layer_on,yes,autocad_layer_plottable,yes,autocad_layer_desc,
GEOTIFF_1_MERGE_DEF GEOTIFF_1::GEOTIFF EXACT GEOTIFF
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "0_ACAD_2 Splitter"    INPUT FEATURE_TYPE 0    OUTPUT FEATURE_TYPE 0_ACAD_2_0_uXCUtW8OIRU=    OUTPUT FEATURE_TYPE 0_ACAD_2_1_MIeWEqDy65Y=
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "GEOTIFF_GEOTIFF_1 Splitter"    INPUT FEATURE_TYPE GEOTIFF    OUTPUT FEATURE_TYPE GEOTIFF_GEOTIFF_1
DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------
FACTORY_DEF {*} GeneralizeFactory    FACTORY_NAME { Generalizer_2 }    INPUT  FEATURE_TYPE 0_ACAD_2_0_uXCUtW8OIRU=    GROUP_BY { autocad_entity_handle }    FLUSH_WHEN_GROUPS_CHANGE { No }    REJECT_INVALID_GEOM Yes    ALLOW_NULLS yes    REJECT_NOT_DEFAULT Yes    PRESERVE_SHARED_BOUNDARIES { Yes }    PRESERVE_PATH_SEGMENTS { YES }    ALGORITHM { Douglas }    TOLERANCE { "0.05" }    FILLET_RADIUS { "<Unused>" }    CLEANING_TOLERANCE { AUTO }    OUTPUT { GENERALIZED FEATURE_TYPE Generalizer_2_OUTPUT          }    OUTPUT { REJECTED FEATURE_TYPE Generalizer_2_<REJECTED>          }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME Generalizer_2_<Rejected> INPUT FEATURE_TYPE Generalizer_2_<REJECTED>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, Generalizer_2<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Translation<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
INCLUDE [          if { ({SPECIFIED} == {SPECIFIED}) } {             puts {MACRO Extruder_func @GeometryType(REJECTABLE, fme_extrusion_exact,"0.0","0.0","-200")};          } else {             puts {MACRO Extruder_func @GeometryType(REJECTABLE, fme_extrusion_exact,0.0,0.0,0.0,"<Unused>","SPECIFIED")};          }          ]
FACTORY_DEF {*} ExecuteFunctionFactory    FACTORY_NAME { Extruder_Rejector }    INPUT  FEATURE_TYPE Generalizer_2_OUTPUT    FUNCTION_DEFINITION { $(Extruder_func) }    OUTPUT { COMPLETE FEATURE_TYPE Extruder_EXTRUDED        }    OUTPUT { REJECTED FEATURE_TYPE Extruder_<REJECTED>        }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME Extruder_<Rejected> INPUT FEATURE_TYPE Extruder_<REJECTED>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, Extruder<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Translation<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { Densifier }    INPUT  FEATURE_TYPE 0_ACAD_2_1_MIeWEqDy65Y=    OUTPUT { FEATURE_TYPE Densifier_DENSIFIED         @AddVertices(xy_uniform,"1")          }
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "VertexExtractor Input Input Collector"   INPUT FEATURE_TYPE Densifier_DENSIFIED   OUTPUT FEATURE_TYPE VertexExtractor_Input
MACRO VertexExtractor_WORKSPACE_NAME VertexExtractor
MACRO $(VertexExtractor_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(VertexExtractor_WORKSPACE_NAME)_XFORMER_NAME VertexExtractor
MACRO $(VertexExtractor_WORKSPACE_NAME)___COMPOUND_PARAMETERS 
MACRO $(VertexExtractor_WORKSPACE_NAME)_DEFAULT_Z_VALUE 
INCLUDE_CUSTOM_TRANSFORMER_VER VertexExtractor:4
FACTORY_DEF * TeeFactory   FACTORY_NAME "VertexExtractor Point Output Renamer/Nuker"   INPUT FEATURE_TYPE VertexExtractor_Point   OUTPUT FEATURE_TYPE VertexExtractor_Point
# -------------------------------------------------------------------------
FACTORY_DEF {*} RasterMosaicFactory    FACTORY_NAME { RasterMosaicker }    INPUT  FEATURE_TYPE GEOTIFF_GEOTIFF_1    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    ACCUMULATE_ATTRIBUTES { ONE }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    OVERLAPPING_VALUES { last }    NODATA_OVERWRITE { No }    INTERPOLATION_TYPE_NAME { NearestNeighbor    }    SNAPPING_TYPE { RESAMPLE }    MERGE_PALETTES { Yes }    REJECT_INVALID_FEATURES YES    OUTPUT { MOSAICKED FEATURE_TYPE RasterMosaicker_OUTPUT          }    OUTPUT { <REJECTED> FEATURE_TYPE RasterMosaicker_<REJECTED>          }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME RasterMosaicker_<Rejected> INPUT FEATURE_TYPE RasterMosaicker_<REJECTED>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, RasterMosaicker<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Translation<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
FACTORY_DEF {*} VectorOnRasterOverlayFactory    FACTORY_NAME { PointOnRasterValueExtractor }    INPUT RASTER FEATURE_TYPE RasterMosaicker_OUTPUT    INPUT VECTOR FEATURE_TYPE VertexExtractor_Point    ACTION RETRIEVE_BAND_AND_PALETTE_VALUES    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INTERPOLATION_TYPE { NearestNeighbor }    REJECT_INVALID_FEATURES Yes    OUTPUT { POINT FEATURE_TYPE PointOnRasterValueExtractor_POINT        }    OUTPUT { REJECTED FEATURE_TYPE PointOnRasterValueExtractor_<REJECTED>        }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME PointOnRasterValueExtractor_<Rejected> INPUT FEATURE_TYPE PointOnRasterValueExtractor_<REJECTED>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, PointOnRasterValueExtractor<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Translation<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
FACTORY_DEF {*} StatisticsCalculatorFactory    FACTORY_NAME { StatisticsCalculator_2 }    INPUT  FEATURE_TYPE PointOnRasterValueExtractor_POINT    GROUP_BY { autocad_entity_handle }    FLUSH_WHEN_GROUPS_CHANGE { No }    FEAT_STATS { _band<opencurly>0<closecurly>.value,NUMERIC_MODE,MIN,,,,,,,,,,,, }    ADVANCED_MODE { NO }    CUMULATIVE_STATS {  }    CALCULATION_MODE { NUMERIC }    ATTR_ACCUM_MODE { None }    ATTRIBUTE_NAMES_AND_TYPES { fme_basename,varchar<openparen>50<closeparen>,_part_number,uint64,_feature_number,int64,_vertex_number,uint32,_x,varchar<openparen>200<closeparen>,_y,varchar<openparen>200<closeparen>,_z,buffer,fme_feature_type,varchar<openparen>50<closeparen>,autocad_entity_handle,varchar<openparen>50<closeparen>,_band<opencurly><closecurly>.value,real64,_band<opencurly><closecurly>.palette<opencurly><closecurly>.value,real64 }    TREAT_INVALID_AS_NULL Yes    OUTPUT { COMPLETE FEATURE_TYPE StatisticsCalculator_2_COMPLETE        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { 3DForcer_3 }    INPUT  FEATURE_TYPE StatisticsCalculator_2_COMPLETE    OUTPUT { FEATURE_TYPE ___TOREJECTOR___         @ZValue("@EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>_band<opencurly>0<closecurly>.value.min<closeparen>,3DForcer_3)", "No", ___fme_rejection_code___) }
