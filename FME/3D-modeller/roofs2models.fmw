DEFAULT_MACRO ACAD_IN_APPLY_WORLD_FILE_TO_ATTRS_ACAD_2 YES
ACAD_2_APPLY_WORLD_FILE_TO_ATTRS "$(ACAD_IN_APPLY_WORLD_FILE_TO_ATTRS_ACAD_2)"
DEFAULT_MACRO ACAD_IN_ENTITY_OPTIONS_ACAD_2 
GUI OPTIONAL DISCLOSUREGROUP ACAD_IN_ENTITY_OPTIONS_ACAD_2 ACAD_IN_RESOLVE_BLOCKS_ACAD_2%ACAD_IN_VISIBLE_ATTRIBUTES_AS_TEXT_ACAD_2%ACAD_IN_EXPLODE_MTEXT_ACAD_2%ACAD_IN_READ_AS_2_5D_ACAD_2 Entity Options
# ============================================================================
# And indicate whether or not we are to expand the blocks.
DEFAULT_MACRO ACAD_IN_RESOLVE_BLOCKS_ACAD_2 yes
