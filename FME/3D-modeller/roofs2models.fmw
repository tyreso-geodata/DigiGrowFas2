ACAD_2_CONVERT_ZERO_LENGTH_ARCS_TO_POINTS "$(ACAD_IN_CONVERT_ZERO_LENGTH_ARCS_TO_POINTS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_CONVERT_ZERO_LENGTH_ARCS_TO_POINTS_ACAD_2 yes%no Convert Zero Length Arcs to Points
# ============================================================================
# PR#9808 - Indicate whether we want to resolve entities color or keep it as ByLayer.
# By default, we'll resolve entity color because that's how we have been doing
# it all along. So to maintain backwards compatibility we'll keep that as default.
DEFAULT_MACRO ACAD_IN_RESOLVE_ENTITY_COLOR_ACAD_2 yes
ACAD_2_RESOLVE_ENTITY_COLOR "$(ACAD_IN_RESOLVE_ENTITY_COLOR_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_RESOLVE_ENTITY_COLOR_ACAD_2 yes%no Resolve Entity Color
# ============================================================================
DEFAULT_MACRO ACAD_IN_PRESERVE_COMPLEX_HATCHES_ACAD_2 no
ACAD_2_PRESERVE_COMPLEX_HATCHES "$(ACAD_IN_PRESERVE_COMPLEX_HATCHES_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_PRESERVE_COMPLEX_HATCHES_ACAD_2 yes%no Preserve Complex Hatches and MPolygons
# ============================================================================
# And indicate whether or not to read groups.
DEFAULT_MACRO ACAD_IN_READ_GROUPS_ACAD_2 no
ACAD_2_READ_GROUPS "$(ACAD_IN_READ_GROUPS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_READ_GROUPS_ACAD_2 yes%no Read Groups
# ============================================================================
# And indicate whether or not to read xrecords from user dictionaries.
DEFAULT_MACRO ACAD_IN_READ_USER_DICTIONARIES_ACAD_2 no
ACAD_2_READ_USER_DICTIONARIES "$(ACAD_IN_READ_USER_DICTIONARIES_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_READ_USER_DICTIONARIES_ACAD_2 yes%no User Dictionary XRecord Data Reading
# ============================================================================
# And indicate whether or not to read xrefs.
DEFAULT_MACRO ACAD_IN_READ_XREFS_ACAD_2 no
ACAD_2_READ_XREFS "$(ACAD_IN_READ_XREFS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_READ_XREFS_ACAD_2 yes%no Read External References
# ============================================================================
# And indicate whether to read mlines as stored vertexes, or as calculated vertexes.
DEFAULT_MACRO ACAD_IN_EVALUATE_MLINE_GEOM_ACAD_2 no
ACAD_2_EVALUATE_MLINE_GEOM "$(ACAD_IN_EVALUATE_MLINE_GEOM_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_EVALUATE_MLINE_GEOM_ACAD_2 yes%no Evaluate Multi-line Entity Geometry
# ============================================================================
# Indicate if we want to store layer properties as feature attributes
DEFAULT_MACRO ACAD_IN_STORE_LAYER_INFO_ACAD_2 no
ACAD_2_STORE_LAYER_INFO "$(ACAD_IN_STORE_LAYER_INFO_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_STORE_LAYER_INFO_ACAD_2 yes%no Store Layer Properties on Features
# ============================================================================
# Decide how we should handle splines
DEFAULT_MACRO ACAD_IN_STORE_SPLINE_DEFS_ACAD_2 yes
ACAD_2_STORE_SPLINE_DEFS "$(ACAD_IN_STORE_SPLINE_DEFS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_STORE_SPLINE_DEFS_ACAD_2 yes%no Store Spline Definitions
# ============================================================================
DEFAULT_MACRO ACAD_IN_RESOLVE_DIMENSIONS_ACAD_2 yes
ACAD_2_RESOLVE_DIMENSIONS "$(ACAD_IN_RESOLVE_DIMENSIONS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_RESOLVE_DIMENSIONS_ACAD_2 yes%no Explode Dimensions
# ============================================================================
DEFAULT_MACRO ACAD_IN_PRESERVE_CLIPPED_RASTERS_ACAD_2 no
ACAD_2_PRESERVE_CLIPPED_RASTERS "$(ACAD_IN_PRESERVE_CLIPPED_RASTERS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_PRESERVE_CLIPPED_RASTERS_ACAD_2 yes%no Preserve Clipped Rasters
# ============================================================================
DEFAULT_MACRO ACAD_IN_IGNORE_FROZEN_LAYERS_ACAD_2 no
ACAD_2_IGNORE_FROZEN_LAYERS "$(ACAD_IN_IGNORE_FROZEN_LAYERS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_IGNORE_FROZEN_LAYERS_ACAD_2 yes%no Ignore Frozen Layers
# ============================================================================
DEFAULT_MACRO ACAD_IN_IGNORE_VIEWPORT_FROZEN_LAYERS_ACAD_2 no
ACAD_2_IGNORE_VIEWPORT_FROZEN_LAYERS "$(ACAD_IN_IGNORE_VIEWPORT_FROZEN_LAYERS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_IGNORE_VIEWPORT_FROZEN_LAYERS_ACAD_2 yes%no Ignore Viewport Frozen Layers
# ============================================================================
DEFAULT_MACRO ACAD_IN_IGNORE_HIDDEN_LAYERS_ACAD_2 yes
ACAD_2_IGNORE_HIDDEN_LAYERS "$(ACAD_IN_IGNORE_HIDDEN_LAYERS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_IGNORE_HIDDEN_LAYERS_ACAD_2 yes%no Ignore Hidden Layers
# ============================================================================
# Should we read proxy graphics - default is YES
DEFAULT_MACRO ACAD_IN_READ_PROXY_GRAPHICS_ACAD_2 yes
ACAD_2_READ_PROXY_GRAPHICS "$(ACAD_IN_READ_PROXY_GRAPHICS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_READ_PROXY_GRAPHICS_ACAD_2 yes%no Read Proxy Entity Graphics
# ============================================================================
# Should we read system variables - default is NO
DEFAULT_MACRO ACAD_IN_READ_SYS_VARS_ACAD_2 no
ACAD_2_READ_SYS_VARS "$(ACAD_IN_READ_SYS_VARS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_READ_SYS_VARS_ACAD_2 yes%no Read Drawing System Variables
# ============================================================================
DEFAULT_MACRO ACAD_IN_READ_REGIONS_AS_AREAS_ACAD_2 yes
ACAD_2_READ_REGIONS_AS_AREAS "$(ACAD_IN_READ_REGIONS_AS_AREAS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_READ_REGIONS_AS_AREAS_ACAD_2 yes%no Read Region Entities as Areas
# ============================================================================
# Should we read rasters - default is YES
DEFAULT_MACRO ACAD_IN_READ_RASTERS_ACAD_2 yes
ACAD_2_READ_RASTERS "$(ACAD_IN_READ_RASTERS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_READ_RASTERS_ACAD_2 yes%no Read Raster Entities
# ============================================================================
DEFAULT_MACRO ACAD_IN_READ_LAYER_DEFS_ACAD_2 no
ACAD_2_READ_LAYER_DEFS "$(ACAD_IN_READ_LAYER_DEFS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_READ_LAYER_DEFS_ACAD_2 yes%no Read Layer Definitions
# ============================================================================
DEFAULT_MACRO ACAD_IN_COORD_SYS_PREFERENCES_GROUP_ACAD_2 
GUI OPTIONAL DISCLOSUREGROUP ACAD_IN_COORD_SYS_PREFERENCES_GROUP_ACAD_2 FME_DISCLOSURE_CLOSED%ACAD_IN_PREFERRED_COORD_SYS_ACAD_2%ACAD_IN_APPLY_WORLD_FILE_ACAD_2%ACAD_IN_IGNORE_UCS_ACAD_2 Coordinate System Preferences
# ============================================================================
# Which coordinate system type does the user prefer? Files could have both types.
DEFAULT_MACRO ACAD_IN_PREFERRED_COORD_SYS_ACAD_2 ESRI
ACAD_2_PREFERRED_COORD_SYS "$(ACAD_IN_PREFERRED_COORD_SYS_ACAD_2)"
GUI LOOKUP_CHOICE ACAD_IN_PREFERRED_COORD_SYS_ACAD_2 Esri,ESRI%Native,NATIVE Preferred Coordinate System Type
# ============================================================================
# 20090504 - Decide if we should apply world (.wld/.wld3) file or not - default is YES
DEFAULT_MACRO ACAD_IN_APPLY_WORLD_FILE_ACAD_2 yes
ACAD_2_APPLY_WORLD_FILE "$(ACAD_IN_APPLY_WORLD_FILE_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_APPLY_WORLD_FILE_ACAD_2 yes%no Apply World File (.wld/.wld3)
# ============================================================================
# 20040114 - Decide if we should handle the user coordinate system (ucs)
DEFAULT_MACRO ACAD_IN_IGNORE_UCS_ACAD_2 no
ACAD_2_IGNORE_UCS "$(ACAD_IN_IGNORE_UCS_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_IGNORE_UCS_ACAD_2 yes%no Ignore User Coordinate System (UCS)
# ============================================================================
DEFAULT_MACRO ACAD_IN_DXF_HEADER_GROUP_ACAD_2 
GUI OPTIONAL DISCLOSUREGROUP ACAD_IN_DXF_HEADER_GROUP_ACAD_2 FME_DISCLOSURE_CLOSED%ACAD_IN_USE_DXF_HEADER_ACAD_2 DXF header
# ============================================================================
DEFAULT_MACRO ACAD_IN_USE_DXF_HEADER_ACAD_2 
ACAD_2_USE_DXF_HEADER "$(ACAD_IN_USE_DXF_HEADER_ACAD_2)"
GUI OPTIONAL FILENAME_MUSTEXIST ACAD_IN_USE_DXF_HEADER_ACAD_2 DXF_Files(*.dxf)|*.dxf|All_files(*.*)|*.* DXF Header File
# ============================================================================
DEFAULT_MACRO ACAD_IN_STRUCTURE_EXTENDED_DATA_ACAD_2 no
ACAD_2_STRUCTURE_EXTENDED_DATA "$(ACAD_IN_STRUCTURE_EXTENDED_DATA_ACAD_2)"
# ============================================================================
DEFAULT_MACRO ACAD_IN_USE_NEW_PAPER_SPACE_PARAMETERS_ACAD_2 yes
ACAD_2_USE_NEW_PAPER_SPACE_PARAMETERS "$(ACAD_IN_USE_NEW_PAPER_SPACE_PARAMETERS_ACAD_2)"
# ===========================================================================
DEFAULT_MACRO ACAD_IN_NETWORK_AUTHENTICATION_ACAD_2 
ACAD_2_NETWORK_AUTHENTICATION "$(ACAD_IN_NETWORK_AUTHENTICATION_ACAD_2)"
GUI OPTIONAL AUTHENTICATOR ACAD_IN_NETWORK_AUTHENTICATION_ACAD_2 CONTAINER%GROUP%CONTAINER_TITLE%"Network Authentication"%PROMPT_TYPE%NETWORK Network Authentication
# ============================================================================
DEFAULT_MACRO ACAD_IN_ATTRIBUTE_READING_ACAD_2 ALL
ACAD_2_ATTRIBUTE_READING "$(ACAD_IN_ATTRIBUTE_READING_ACAD_2)"
# ============================================================================
ACAD_2_GENERATE_FME_BUILD_NUM 24820
# ============================================================================
# Bring in macros for all the autocad colors
INCLUDE "$(FME_HOME)/metafile/autocadColors.fmi"
ACAD_2_DATASET "$(SourceDataset_ACAD_2)"
