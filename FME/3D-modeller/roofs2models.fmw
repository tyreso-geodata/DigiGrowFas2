GUI ACTIVEDISCLOSUREGROUP ACAD_IN_RESOLVE_BLOCKS_ACAD_2 FME_DISCLOSURE_CLOSED%ACAD_IN_USE_BLOCK_HEADER_LAYER_ACAD_2%ACAD_IN_USE_BLOCK_LAYER_INFO_ACAD_2%ACAD_IN_STORE_INSERT_POINT_ACAD_2%ACAD_IN_PRESERVE_INSERTS_ACAD_2%ACAD_IN_READ_AS_GEOM_INSTANCES_ACAD_2%ACAD_IN_RESOLVE_SELECTED_BLOCKS_ACAD_2 Explode Blocks into Entities
GUI LOOKUP ACAD_IN_RESOLVE_BLOCKS_ACAD_2 YES,yes%NO,no 
# ============================================================================
# Indicate whether we want to use the block header feature type for the components
# when blocks are exploded or to read components on their original feature types.
DEFAULT_MACRO ACAD_IN_USE_BLOCK_HEADER_LAYER_ACAD_2 yes
ACAD_2_USE_BLOCK_HEADER_LAYER "$(ACAD_IN_USE_BLOCK_HEADER_LAYER_ACAD_2)"
GUI OPTIONAL CHECKBOX_WITHLABEL ACAD_IN_USE_BLOCK_HEADER_LAYER_ACAD_2 yes%no Use Block Feature Type for Components
GUI LOOKUP ACAD_IN_USE_BLOCK_HEADER_LAYER_ACAD_2 <Unused>,no 
# ============================================================================
# Indicate whether we want to use the block header layer information for the components
# when blocks are exploded or to read components with their original layer information.
