#! <ATTR_LINKS>
#! </ATTR_LINKS>
#! <SUBDOCUMENTS>
#! </SUBDOCUMENTS>
#! <LOOKUP_TABLES>
#! </LOOKUP_TABLES>
#! </WORKSPACE>

FME_PYTHON_VERSION 310
ARCGIS_COMPATIBILITY ARCGIS_AUTO
GUI IGNORE SourceDataset_ESRIASCIIGRID_1,ESRIASCIIGRID_IN_USE_SEARCH_ENVELOPE_ESRIASCIIGRID_1,ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MINX_ESRIASCIIGRID_1,ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MINY_ESRIASCIIGRID_1,ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MAXX_ESRIASCIIGRID_1,ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MAXY_ESRIASCIIGRID_1,ESRIASCIIGRID_IN_SEARCH_ENVELOPE_COORDINATE_SYSTEM_ESRIASCIIGRID_1,ESRIASCIIGRID_IN_CLIP_TO_ENVELOPE_ESRIASCIIGRID_1,ESRIASCIIGRID_IN_NETWORK_AUTHENTICATION_ESRIASCIIGRID_1,DestDataset_GEOTIFF_1,GEOTIFF_OUT_GEOTIFF_WRT_ADV_PARM_GROUP_GEOTIFF_1,GEOTIFF_OUT_WRITE_OFFSETS_IN_CS_UNITS_GEOTIFF_1,GEOTIFF_OUT_WRITE_PROJECTED_COORDSYS_AS_EPSG_CODE_GEOTIFF_1,GEOTIFF_OUT_WRITE_GEOGRAPHIC_COORDSYS_AS_EPSG_CODE_GEOTIFF_1,GEOTIFF_OUT_WRITE_GEOGRAPHIC_KEYS_FOR_PROJECTED_COORDSYS_GEOTIFF_1,GEOTIFF_OUT_WRITE_ESRI_COMPATIBLE_COORDSYS_GEOTIFF_1,GEOTIFF_OUT_IGNORE_RASTER_TYPE_KEY_GEOTIFF_1
# ============================================================================
DEFAULT_MACRO SourceDataset_ESRIASCIIGRID ""$(FME_MF_DIR)MARKMODELL\01m\ASCII\*.asc" "$(FME_MF_DIR)MARKMODELL\01m\ASCII\*.grd""

DEFAULT_MACRO DestDataset_GEOTIFF $(FME_MF_DIR)MARKMODELL\01m\GEOTIFF

# ============================================================================
INCLUDE [ if {{$(SourceDataset_ESRIASCIIGRID$encode)} == {}} { puts_real {Parameter 'SourceDataset_ESRIASCIIGRID' must be given a value.}; exit 1; }; ]
INCLUDE [ if {{$(DestDataset_GEOTIFF$encode)} == {}} { puts_real {Parameter 'DestDataset_GEOTIFF' must be given a value.}; exit 1; }; ]
#! START_HEADER
#! START_WB_HEADER
READER_TYPE MULTI_READER
MULTI_READER_TYPE{0} ESRIASCIIGRID
MULTI_READER_KEYWORD{0} ESRIASCIIGRID_1
MULTI_READER_GEN_DIRECTIVES{0} ESRIASCIIGRID_EXPOSE_FORMAT_ATTRS,,SEARCH_ENVELOPE_COORDINATE_SYSTEM,,USE_SEARCH_ENVELOPE,NO,SEARCH_ENVELOPE_MAXY,0,SEARCH_ENVELOPE_MINX,0,_MERGE_SCHEMAS,YES,CLIP_TO_ENVELOPE,NO,SEARCH_ENVELOPE_MINY,0,GROUP_BY_DATASET,No,_EXTRA_DATASETS,C:<backslash>Users<backslash>SEIAMM<backslash>Documents<backslash>tyres<u00f6><backslash>BLOCK_1000<backslash>MARKMODELL<backslash>10m<backslash>ASCII<backslash>*.grd,SEARCH_ENVELOPE_MAXX,0,READER_META_ATTRIBUTES,fme_basename,EXPOSE_ATTRS_GROUP,
WRITER_TYPE MULTI_WRITER
WRITER_KEYWORD PRIMARY_DEST
PRIMARY_DEST_DATASET_ORDER BY_ID
PRIMARY_DEST_FIRST_WRITER_ID 0
PRIMARY_DEST_TYPE{0} GEOTIFF
PRIMARY_DEST_KEYWORD{0} GEOTIFF_1
PRIMARY_DEST_GEN_DIRECTIVES{0} FORMAT_ATTRIBUTES_OVERRIDE_FEATURE_TYPE_PARAMETERS,No,WRITE_GEOGRAPHIC_KEYS_FOR_PROJECTED_COORDSYS,Yes,IGNORE_RASTER_TYPE_KEY,No,COORDINATE_SYSTEM_GRANULARITY,FEATURE,ADD_WRITER_NEXT_ACTION,automatic,WRITE_ESRI_COMPATIBLE_COORDSYS,No,WRITE_PROJECTED_COORDSYS_AS_EPSG_CODE,Yes,DESTINATION_DATASETTYPE_VALIDATION,Yes,GEOTIFF_WRT_ADV_PARM_GROUP,,WRITE_OFFSETS_IN_CS_UNITS,Yes,WRITE_GEOGRAPHIC_COORDSYS_AS_EPSG_CODE,Yes
#! END_WB_HEADER
#! START_WB_HEADER
MACRO WB_KEYWORD "ESRIASCIIGRID_1"
#! END_WB_HEADER
#! START_SOURCE_HEADER ESRIASCIIGRID ESRIASCIIGRID_1
# ============================================================================
# The following GUI line prompts for a folder to be used as the
# source of the ESRIASCIIGRID based files.
# The user input is stored in a macro, which is then used to define
# the dataset to be read.
# The dataset this mapping file was generated from was:
#! END_SOURCE_HEADER
#! START_WB_HEADER
DEFAULT_MACRO SourceDataset
INCLUDE [ if {{$(SourceDataset)} != ""} {                        \
 puts {DEFAULT_MACRO SourceDataset_ESRIASCIIGRID_1 $(SourceDataset)}     \
 } ]
#! END_WB_HEADER
#! START_SOURCE_HEADER ESRIASCIIGRID ESRIASCIIGRID_1
DEFAULT_MACRO SourceDataset_ESRIASCIIGRID_1 $(SourceDataset_ESRIASCIIGRID)
GUI MULTIFILE SourceDataset_ESRIASCIIGRID_1 ASC_Files(*.asc)/GRD_Files(*.grd)|*.asc;*.grd|ASC_Files(*.asc)|*.asc|GRD_Files(*.grd)|*.grd|All_Files(*)|* Source Esri ASCII Grid File(s):
DEFAULT_MACRO ESRIASCIIGRID_IN_READER_META_ATTRIBUTES_ESRIASCIIGRID_1 fme_basename
ESRIASCIIGRID_1_READER_META_ATTRIBUTES "$(ESRIASCIIGRID_IN_READER_META_ATTRIBUTES_ESRIASCIIGRID_1)"
DEFAULT_MACRO ESRIASCIIGRID_IN_GROUP_BY_DATASET_ESRIASCIIGRID_1 No
ESRIASCIIGRID_1_GROUP_BY_DATASET "$(ESRIASCIIGRID_IN_GROUP_BY_DATASET_ESRIASCIIGRID_1)"
DEFAULT_MACRO ESRIASCIIGRID_IN_EXPOSE_ATTRS_GROUP_ESRIASCIIGRID_1 
ESRIASCIIGRID_1_EXPOSE_ATTRS_GROUP "$(ESRIASCIIGRID_IN_EXPOSE_ATTRS_GROUP_ESRIASCIIGRID_1)"
# Include this file in source setting section to add external search envelope processing
# Zero as a default means we don't do any search -- this makes workbench happier
DEFAULT_MACRO ESRIASCIIGRID_IN_USE_SEARCH_ENVELOPE_ESRIASCIIGRID_1 NO
ESRIASCIIGRID_1_USE_SEARCH_ENVELOPE "$(ESRIASCIIGRID_IN_USE_SEARCH_ENVELOPE_ESRIASCIIGRID_1)"
GUI ACTIVEDISCLOSUREGROUP ESRIASCIIGRID_IN_USE_SEARCH_ENVELOPE_ESRIASCIIGRID_1 ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MINX_ESRIASCIIGRID_1%ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MINY_ESRIASCIIGRID_1%ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MAXX_ESRIASCIIGRID_1%ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MAXY_ESRIASCIIGRID_1%ESRIASCIIGRID_IN_SEARCH_ENVELOPE_COORDINATE_SYSTEM_ESRIASCIIGRID_1%ESRIASCIIGRID_IN_CLIP_TO_ENVELOPE_ESRIASCIIGRID_1%ESRIASCIIGRID_IN_SEARCH_METHOD%ESRIASCIIGRID_IN_SEARCH_METHOD_FILTER%ESRIASCIIGRID_IN_SEARCH_ORDER%ESRIASCIIGRID_IN_SEARCH_FEATURE%ESRIASCIIGRID_IN_DUMMY_SEARCH_ENVELOPE_PARAMETER Use Search Envelope
# ===========================================================================
GUI LOOKUP ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MINX_ESRIASCIIGRID_1 <Unused>,0 
DEFAULT_MACRO ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MINX_ESRIASCIIGRID_1 0
ESRIASCIIGRID_1_SEARCH_ENVELOPE "$(ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MINX_ESRIASCIIGRID_1)"
GUI OPTIONAL FLOAT ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MINX_ESRIASCIIGRID_1 Minimum X:
# ===========================================================================
GUI LOOKUP ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MINY_ESRIASCIIGRID_1 <Unused>,0 
DEFAULT_MACRO ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MINY_ESRIASCIIGRID_1 0
ESRIASCIIGRID_1_SEARCH_ENVELOPE "$(ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MINY_ESRIASCIIGRID_1)"
GUI OPTIONAL FLOAT ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MINY_ESRIASCIIGRID_1 Minimum Y:
# ===========================================================================
GUI LOOKUP ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MAXX_ESRIASCIIGRID_1 <Unused>,0 
DEFAULT_MACRO ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MAXX_ESRIASCIIGRID_1 0
ESRIASCIIGRID_1_SEARCH_ENVELOPE "$(ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MAXX_ESRIASCIIGRID_1)"
GUI OPTIONAL FLOAT ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MAXX_ESRIASCIIGRID_1 Maximum X:
# ===========================================================================
GUI LOOKUP ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MAXY_ESRIASCIIGRID_1 <Unused>,0 
DEFAULT_MACRO ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MAXY_ESRIASCIIGRID_1 0
ESRIASCIIGRID_1_SEARCH_ENVELOPE "$(ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MAXY_ESRIASCIIGRID_1)"
GUI OPTIONAL FLOAT ESRIASCIIGRID_IN_SEARCH_ENVELOPE_MAXY_ESRIASCIIGRID_1 Maximum Y:
# ===========================================================================
GUI LOOKUP ESRIASCIIGRID_IN_SEARCH_ENVELOPE_COORDINATE_SYSTEM_ESRIASCIIGRID_1 <Unused>, 
DEFAULT_MACRO ESRIASCIIGRID_IN_SEARCH_ENVELOPE_COORDINATE_SYSTEM_ESRIASCIIGRID_1 
ESRIASCIIGRID_1_SEARCH_ENVELOPE "$(ESRIASCIIGRID_IN_SEARCH_ENVELOPE_COORDINATE_SYSTEM_ESRIASCIIGRID_1)"
GUI OPTIONAL COORDSYS ESRIASCIIGRID_IN_SEARCH_ENVELOPE_COORDINATE_SYSTEM_ESRIASCIIGRID_1 Search Envelope Coordinate System:
# ===========================================================================
# BUG18999: We now have a soft clip to fall back on like native spatial index
# thus we are reintroducing the clip to envelop as an option for users.
# Defualt to soft clip as per the existing database readers we are emulating
GUI LOOKUP ESRIASCIIGRID_IN_CLIP_TO_ENVELOPE_ESRIASCIIGRID_1 <Unused>,NO 
DEFAULT_MACRO ESRIASCIIGRID_IN_CLIP_TO_ENVELOPE_ESRIASCIIGRID_1 NO
ESRIASCIIGRID_1_CLIP_TO_ENVELOPE "$(ESRIASCIIGRID_IN_CLIP_TO_ENVELOPE_ESRIASCIIGRID_1)"
GUI OPTIONAL CHECKBOX ESRIASCIIGRID_IN_CLIP_TO_ENVELOPE_ESRIASCIIGRID_1 YES%NO Clip to Search Envelope
# ===========================================================================
DEFAULT_MACRO ESRIASCIIGRID_IN_NETWORK_AUTHENTICATION_ESRIASCIIGRID_1 
ESRIASCIIGRID_1_NETWORK_AUTHENTICATION "$(ESRIASCIIGRID_IN_NETWORK_AUTHENTICATION_ESRIASCIIGRID_1)"
GUI OPTIONAL AUTHENTICATOR ESRIASCIIGRID_IN_NETWORK_AUTHENTICATION_ESRIASCIIGRID_1 CONTAINER%GROUP%CONTAINER_TITLE%"Network Authentication"%PROMPT_TYPE%NETWORK Network Authentication
# ============================================================================
DEFAULT_MACRO ESRIASCIIGRID_IN_ATTRIBUTE_READING_ESRIASCIIGRID_1 ALL
ESRIASCIIGRID_1_ATTRIBUTE_READING "$(ESRIASCIIGRID_IN_ATTRIBUTE_READING_ESRIASCIIGRID_1)"
# ============================================================================
ESRIASCIIGRID_1_GENERATE_FME_BUILD_NUM 24820
ESRIASCIIGRID_1_DATASET "$(SourceDataset_ESRIASCIIGRID_1)"
#! END_SOURCE_HEADER
#! START_WB_HEADER
MACRO WB_KEYWORD "GEOTIFF_1"
#! END_WB_HEADER
#! START_DEST_HEADER GEOTIFF GEOTIFF_1
# The following GUI lines prompt for a GEOTIFF file to be used as the
# the destination of the data.
# The user input is stored in a macro, which is then used to define
# the dataset to be written.
#! END_DEST_HEADER
#! START_WB_HEADER
DEFAULT_MACRO DestDataset
INCLUDE [ if {"$(DestDataset)" != ""} {                          \
 puts {DEFAULT_MACRO DestDataset_GEOTIFF_1 $(DestDataset)}         \
 } ]
#! END_WB_HEADER
#! START_DEST_HEADER GEOTIFF GEOTIFF_1
DEFAULT_MACRO DestDataset_GEOTIFF_1 $(DestDataset_GEOTIFF)
GUI DIRNAME DestDataset_GEOTIFF_1 Destination GeoTIFF Folder:
DEFAULT_MACRO _GEOTIFF_WRITER_WORLD_FILE_GENERATION_GEOTIFF_1 no
DEFAULT_MACRO _GEOTIFF_WRITER_CREATE_TILED_FILES_GEOTIFF_1 no
DEFAULT_MACRO _GEOTIFF_WRITER_TILE_SIZE_X_GEOTIFF_1 
DEFAULT_MACRO _GEOTIFF_WRITER_TILE_SIZE_Y_GEOTIFF_1 
DEFAULT_MACRO _GEOTIFF_WRITER_COMPRESSION_METHOD_GEOTIFF_1 none
DEFAULT_MACRO _GEOTIFF_WRITER_JPEG_COMPRESSION_LEVEL_GEOTIFF_1 25
DEFAULT_MACRO _GEOTIFF_WRITER_DEFLATE_COMPRESSION_LEVEL_GEOTIFF_1 6
DEFAULT_MACRO _GEOTIFF_WRITER_ZSTD_COMPRESSION_LEVEL_GEOTIFF_1 9
DEFAULT_MACRO _GEOTIFF_WRITER_LERC_MAX_Z_ERROR_GEOTIFF_1 0
DEFAULT_MACRO _GEOTIFF_WRITER_TAB_FILE_GENERATION_GEOTIFF_1 no
DEFAULT_MACRO _GEOTIFF_WRITER_NUMBER_OF_BITS_PER_CELL_GEOTIFF_1 
DEFAULT_MACRO _GEOTIFF_WRITER_ENABLE_BIGTIFF_GEOTIFF_1 no
DEFAULT_MACRO _GEOTIFF_WRITER_INTERLEAVING_TYPE_GEOTIFF_1 BSQ
DEFAULT_MACRO _GEOTIFF_WRITER_PHOTOMETRIC_INTERPRETATION_GEOTIFF_1 Auto
DEFAULT_MACRO _GEOTIFF_WRITER_BYTE_ORDER_GEOTIFF_1 machine
DEFAULT_MACRO _GEOTIFF_WRITER_CALCULATE_MINMAX_TIFFTAGS_GEOTIFF_1 no
DEFAULT_MACRO _GEOTIFF_WRITER_GENERATE_PYRAMIDS_GEOTIFF_1 no
DEFAULT_MACRO _GEOTIFF_WRITER_PYRAMID_NUM_LEVELS_GEOTIFF_1 
DEFAULT_MACRO _GEOTIFF_WRITER_PYRAMID_INTERPOLATION_TYPE_GEOTIFF_1 NearestNeighbor
DEFAULT_MACRO _GEOTIFF_WRITER_PYRAMID_TILE_SIZE_GEOTIFF_1 128
DEFAULT_MACRO GEOTIFF_OUT_FORMAT_ATTRIBUTES_OVERRIDE_FEATURE_TYPE_PARAMETERS_GEOTIFF_1 No
GEOTIFF_1_FORMAT_ATTRIBUTES_OVERRIDE_FEATURE_TYPE_PARAMETERS "$(GEOTIFF_OUT_FORMAT_ATTRIBUTES_OVERRIDE_FEATURE_TYPE_PARAMETERS_GEOTIFF_1)"
DEFAULT_MACRO GEOTIFF_OUT_GEOTIFF_WRT_ADV_PARM_GROUP_GEOTIFF_1 FME_DISCLOSURE_CLOSED
GUI OPTIONAL DISCLOSUREGROUP GEOTIFF_OUT_GEOTIFF_WRT_ADV_PARM_GROUP_GEOTIFF_1 GEOTIFF_OUT_WRITE_OFFSETS_IN_CS_UNITS_GEOTIFF_1%GEOTIFF_OUT_WRITE_PROJECTED_COORDSYS_AS_EPSG_CODE_GEOTIFF_1%GEOTIFF_OUT_WRITE_GEOGRAPHIC_COORDSYS_AS_EPSG_CODE_GEOTIFF_1%GEOTIFF_OUT_WRITE_GEOGRAPHIC_KEYS_FOR_PROJECTED_COORDSYS_GEOTIFF_1%GEOTIFF_OUT_WRITE_ESRI_COMPATIBLE_COORDSYS_GEOTIFF_1%GEOTIFF_OUT_IGNORE_RASTER_TYPE_KEY_GEOTIFF_1 Advanced
DEFAULT_MACRO GEOTIFF_OUT_WRITE_OFFSETS_IN_CS_UNITS_GEOTIFF_1 Yes
GEOTIFF_1_WRITE_OFFSETS_IN_CS_UNITS "$(GEOTIFF_OUT_WRITE_OFFSETS_IN_CS_UNITS_GEOTIFF_1)"
GUI CHOICE GEOTIFF_OUT_WRITE_OFFSETS_IN_CS_UNITS_GEOTIFF_1 Yes%No Offsets in Coordinate System Units:
DEFAULT_MACRO GEOTIFF_OUT_WRITE_PROJECTED_COORDSYS_AS_EPSG_CODE_GEOTIFF_1 Yes
GEOTIFF_1_WRITE_PROJECTED_COORDSYS_AS_EPSG_CODE "$(GEOTIFF_OUT_WRITE_PROJECTED_COORDSYS_AS_EPSG_CODE_GEOTIFF_1)"
GUI CHOICE GEOTIFF_OUT_WRITE_PROJECTED_COORDSYS_AS_EPSG_CODE_GEOTIFF_1 Yes%No Write Projected Coordinate System as EPSG Code:
DEFAULT_MACRO GEOTIFF_OUT_WRITE_GEOGRAPHIC_COORDSYS_AS_EPSG_CODE_GEOTIFF_1 Yes
GEOTIFF_1_WRITE_GEOGRAPHIC_COORDSYS_AS_EPSG_CODE "$(GEOTIFF_OUT_WRITE_GEOGRAPHIC_COORDSYS_AS_EPSG_CODE_GEOTIFF_1)"
GUI CHOICE GEOTIFF_OUT_WRITE_GEOGRAPHIC_COORDSYS_AS_EPSG_CODE_GEOTIFF_1 Yes%No Write Geographic Coordinate System as EPSG Code:
DEFAULT_MACRO GEOTIFF_OUT_WRITE_GEOGRAPHIC_KEYS_FOR_PROJECTED_COORDSYS_GEOTIFF_1 Yes
GEOTIFF_1_WRITE_GEOGRAPHIC_KEYS_FOR_PROJECTED_COORDSYS "$(GEOTIFF_OUT_WRITE_GEOGRAPHIC_KEYS_FOR_PROJECTED_COORDSYS_GEOTIFF_1)"
GUI CHOICE GEOTIFF_OUT_WRITE_GEOGRAPHIC_KEYS_FOR_PROJECTED_COORDSYS_GEOTIFF_1 Yes%No Write Geographic Keys for Projected Coordinate Systems:
DEFAULT_MACRO GEOTIFF_OUT_WRITE_ESRI_COMPATIBLE_COORDSYS_GEOTIFF_1 No
GEOTIFF_1_WRITE_ESRI_COMPATIBLE_COORDSYS "$(GEOTIFF_OUT_WRITE_ESRI_COMPATIBLE_COORDSYS_GEOTIFF_1)"
GUI CHOICE GEOTIFF_OUT_WRITE_ESRI_COMPATIBLE_COORDSYS_GEOTIFF_1 Yes%No Write Esri-Compatible Coordinate System:
DEFAULT_MACRO GEOTIFF_OUT_IGNORE_RASTER_TYPE_KEY_GEOTIFF_1 No
GEOTIFF_1_IGNORE_RASTER_TYPE_KEY "$(GEOTIFF_OUT_IGNORE_RASTER_TYPE_KEY_GEOTIFF_1)"
GUI CHOICE GEOTIFF_OUT_IGNORE_RASTER_TYPE_KEY_GEOTIFF_1 Yes%No Ignore Raster Type Key:
# ============================================================================
# Opt in for destination dataset type vs format type validation
DEFAULT_MACRO GEOTIFF_OUT_DESTINATION_DATASETTYPE_VALIDATION_GEOTIFF_1 Yes
GEOTIFF_1_DESTINATION_DATASETTYPE_VALIDATION "$(GEOTIFF_OUT_DESTINATION_DATASETTYPE_VALIDATION_GEOTIFF_1)"
DEFAULT_MACRO GEOTIFF_OUT_COORDINATE_SYSTEM_GRANULARITY_GEOTIFF_1 FEATURE
GEOTIFF_1_COORDINATE_SYSTEM_GRANULARITY "$(GEOTIFF_OUT_COORDINATE_SYSTEM_GRANULARITY_GEOTIFF_1)"
DEFAULT_MACRO GEOTIFF_OUT_FORMAT_ATTRIBUTES_OVERRIDE_FEATURE_TYPE_PARAMETERS_GEOTIFF_1 No
GEOTIFF_1_FORMAT_ATTRIBUTES_OVERRIDE_FEATURE_TYPE_PARAMETERS "$(GEOTIFF_OUT_FORMAT_ATTRIBUTES_OVERRIDE_FEATURE_TYPE_PARAMETERS_GEOTIFF_1)"
# ============================================================================
GEOTIFF_1_GENERATE_FME_BUILD_NUM 24820
GEOTIFF_1_DATASET "$(DestDataset_GEOTIFF_1)"
#! END_DEST_HEADER
#! START_WB_HEADER
#! END_WB_HEADER
#! END_HEADER

LOG_FILENAME "$(FME_MF_DIR)$(WORKSPACE_NAME).log"
LOG_APPEND NO
LOG_MAX_FEATURES 200
LOG_MAX_RECORDED_FEATURES 200
FME_REPROJECTION_ENGINE FME
FME_IMPLICIT_CSMAP_REPROJECTION_MODE Auto
FME_GEOMETRY_HANDLING Enhanced
FME_STROKE_MAX_DEVIATION 0
FME_NAMES_ENCODING UTF-8
FME_BULK_MODE_THRESHOLD 2000
LAST_SAVE_BUILD "FME 2025.2.4.0 (20260225 - Build 25835 - WIN64)"
DEFAULT_MACRO DATASET_KEYWORD_ESRIASCIIGRID_1 ESRIASCIIGRID_1
DEFAULT_MACRO DATASET_KEYWORD_GEOTIFF_1 GEOTIFF_1
# -------------------------------------------------------------------------

ESRIASCIIGRID_1_READER_META_ATTRIBUTES fme_basename fme_feature_type

# -------------------------------------------------------------------------

ESRIASCIIGRID_1_COORDINATE_SYSTEM EPSG:3011
GEOTIFF_1_COORDINATE_SYSTEM EPSG:3011
MULTI_READER_CONTINUE_ON_READER_FAILURE No

# -------------------------------------------------------------------------

MACRO FME_VIEWER_APP fmedatainspector
# -------------------------------------------------------------------------
ESRIASCIIGRID_1_DEF ESRIASCIIGRID
# -------------------------------------------------------------------------

FACTORY_DEF * RoutingFactory   FACTORY_NAME "Router and Unexpected Input Remover"   COMMAND_PARM_EVALUATION SINGLE_PASS   MULTI_READER_KEYWORD $(DATASET_KEYWORD_ESRIASCIIGRID_1)   INPUT FEATURE_TYPE *    ROUTE ESRIASCIIGRID ESRIASCIIGRID_1::ESRIASCIIGRID multi_reader_keyword,$(DATASET_KEYWORD_ESRIASCIIGRID_1) TO FME_GENERIC ::ESRIASCIIGRID ALIAS_GEOMETRY    MERGE_INPUT Yes   OUTPUT ROUTED FEATURE_TYPE *
ESRIASCIIGRID_1_MERGE_DEF ESRIASCIIGRID_1::ESRIASCIIGRID EXACT ESRIASCIIGRID
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "ESRIASCIIGRID_ESRIASCIIGRID_1 Splitter"    INPUT FEATURE_TYPE ESRIASCIIGRID    OUTPUT FEATURE_TYPE ESRIASCIIGRID_ESRIASCIIGRID_1
DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------

FACTORY_DEF * RoutingFactory FACTORY_NAME "Destination Feature Type Routing Correlator"   COMMAND_PARM_EVALUATION SINGLE_PASS   INPUT FEATURE_TYPE *    ROUTE FME_GENERIC ESRIASCIIGRID_ESRIASCIIGRID_1 TO GEOTIFF __GO_TO_FINAL_OUTPUT_ROUTER__ multi_writer_id,0,<at>SupplyAttributes<openparen>ENCODED<comma>fme_template_feature_type<comma>Raster1<closeparen>,<at>EvaluateExpression<openparen>ATTR_CREATE_EXPR<comma>__wb_out_feat_type__<comma><lt>at<gt>Value<lt>openparen<gt>fme_basename<lt>closeparen<gt><comma>Raster1<closeparen> COORDINATE_SYSTEM EPSG:3011 GEOMETRY   FEATURE_TYPE_ATTRIBUTE __wb_out_feat_type__   OUTPUT ROUTED FEATURE_TYPE *    OUTPUT NOT_ROUTED FEATURE_TYPE __nuke_me__ @Tcl2("FME_StatMessage 818059 [FME_GetAttribute fme_template_feature_type] 818060 818061 fme_warn")
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory   FACTORY_NAME "Final Output Nuker"   INPUT FEATURE_TYPE __nuke_me__

# -------------------------------------------------------------------------
GEOTIFF_1_DEF Raster1   geotiff_world_file_generation no   geotiff_create_tiled_files   no   geotiff_tile_size_x          ""   geotiff_tile_size_y          ""   geotiff_compression_method   none   geotiff_jpeg_compression_level 25   geotiff_deflate_compression_level 6   geotiff_zstd_compression_level 9   geotiff_lerc_max_z_error     0   geotiff_tab_file_generation  no   geotiff_number_of_bits_per_cell ""   geotiff_enable_bigtiff       no   geotiff_interleaving_type    BSQ   geotiff_photometric_interpretation Auto   geotiff_byte_order           machine   geotiff_calculate_minmax_tifftags no   geotiff_generate_pyramids    NO
