FACTORY_DEF * RoutingFactory   FACTORY_NAME "Router and Unexpected Input Remover"   COMMAND_PARM_EVALUATION SINGLE_PASS   MULTI_READER_KEYWORD $(DATASET_KEYWORD_ACAD_1)   INPUT FEATURE_TYPE *    ROUTE ACAD ACAD_1::0 multi_reader_keyword,$(DATASET_KEYWORD_ACAD_1) TO FME_GENERIC ::0 ALIAS_GEOMETRY    MERGE_INPUT Yes   OUTPUT ROUTED FEATURE_TYPE *
ACAD_1_MERGE_DEF ACAD_1::0 GLOB * DEFLINE autocad_color,10,autocad_linetype,CONTINUOUS,autocad_layer_frozen,no,autocad_layer_hidden,no,autocad_layer_locked,no,autocad_layer_on,yes,autocad_layer_plottable,yes,autocad_layer_desc,
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "0_ACAD_1 Splitter"    INPUT FEATURE_TYPE 0    OUTPUT FEATURE_TYPE 0_ACAD_1_0_uXCUtW8OIRU=    OUTPUT FEATURE_TYPE 0_ACAD_1_1_MIeWEqDy65Y=
DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------
# If we're doing LAST N features, then the multiplier comes in as 0.
# If we're doing First N, multiplier is -1.
# For RANDOM, we need to treat LAST N as if it was first N (i.e. have a -1)
# That is what the ? : does in the rate multiplier.
INCLUDE [ if { {1} == {0} && {RANDOM} == {ORIGINAL} } {              puts "MACRO REAL_MODE LAST"; 	         puts "MACRO REAL_RATE 50"; 	      } else {              puts "MACRO REAL_MODE RANDOM";              puts "MACRO REAL_RATE [expr 50 * ( 1 ? 1 : -1 ) ]"; 	      } ]
FACTORY_DEF {*} SamplingFactory    FACTORY_NAME { Sampler }    COMMAND_PARM_EVALUATION SINGLE_PASS    SAMPLE_RATE { $(REAL_RATE) }    SAMPLE_ORDER { $(REAL_MODE) }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT  FEATURE_TYPE 0_ACAD_1_1_MIeWEqDy65Y=    OUTPUT { SAMPLED FEATURE_TYPE ___SAMPLED___ }
# This TeeFactory is needed because Sampler will still output features if it has no OUTPUT clauses specified.
# This way we behave nicely even if there are no output connections on the transformer. See PR#28886.
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { Sampler_Sampled }    INPUT FEATURE_TYPE ___SAMPLED___    OUTPUT { FEATURE_TYPE Sampler_SAMPLED          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} GeometryFilterFactory    COMMAND_PARM_EVALUATION SINGLE_PASS    FACTORY_NAME { GeometryFilter }    INPUT  FEATURE_TYPE Sampler_SAMPLED    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    FILTER_TYPES { GeometryInstance,Aggregate,Area,Donut,SimpleArea,Ellipse,Polygon,Curve,Path,Segment,Arc,BSpline,Clothoid,Line,OrientedArc,MultiArea,MultiCurve,MultiPoint,MultiSolid,MultiSurface,MultiText,Null,Point,PointCloud,Raster,Solid,CompositeSolid,SimpleSolid,BRepSolid,Box,CSGSolid,Extrusion,Pipe,Surface,CompositeSurface,SimpleSurface,Face,Mesh,RectangleFace,TriangleFan,TriangleStrip,Text,VoxelGrid }    INSTANCES { INSTANCE }    OUTPUT { <UNFILTERED> FEATURE_TYPE GeometryFilter_<UNFILTERED>  }    OUTPUT { GeometryInstance FEATURE_TYPE GeometryFilter_GeometryInstance  }    OUTPUT { Aggregate FEATURE_TYPE GeometryFilter_Aggregate  }    OUTPUT { Area FEATURE_TYPE GeometryFilter_Area  }    OUTPUT { Donut FEATURE_TYPE GeometryFilter_Donut  }    OUTPUT { SimpleArea FEATURE_TYPE GeometryFilter_SimpleArea  }    OUTPUT { Ellipse FEATURE_TYPE GeometryFilter_Ellipse  }    OUTPUT { Polygon FEATURE_TYPE GeometryFilter_Polygon  }    OUTPUT { Curve FEATURE_TYPE GeometryFilter_Curve  }    OUTPUT { Path FEATURE_TYPE GeometryFilter_Path  }    OUTPUT { Segment FEATURE_TYPE GeometryFilter_Segment  }    OUTPUT { Arc FEATURE_TYPE GeometryFilter_Arc  }    OUTPUT { BSpline FEATURE_TYPE GeometryFilter_BSpline  }    OUTPUT { Clothoid FEATURE_TYPE GeometryFilter_Clothoid  }    OUTPUT { Line FEATURE_TYPE GeometryFilter_Line  }    OUTPUT { OrientedArc FEATURE_TYPE GeometryFilter_OrientedArc  }    OUTPUT { MultiArea FEATURE_TYPE GeometryFilter_MultiArea  }    OUTPUT { MultiCurve FEATURE_TYPE GeometryFilter_MultiCurve  }    OUTPUT { MultiPoint FEATURE_TYPE GeometryFilter_MultiPoint  }    OUTPUT { MultiSolid FEATURE_TYPE GeometryFilter_MultiSolid  }    OUTPUT { MultiSurface FEATURE_TYPE GeometryFilter_MultiSurface  }    OUTPUT { MultiText FEATURE_TYPE GeometryFilter_MultiText  }    OUTPUT { Null FEATURE_TYPE GeometryFilter_Null  }    OUTPUT { Point FEATURE_TYPE GeometryFilter_Point  }    OUTPUT { PointCloud FEATURE_TYPE GeometryFilter_PointCloud  }    OUTPUT { Raster FEATURE_TYPE GeometryFilter_Raster  }    OUTPUT { Solid FEATURE_TYPE GeometryFilter_Solid  }    OUTPUT { CompositeSolid FEATURE_TYPE GeometryFilter_CompositeSolid  }    OUTPUT { SimpleSolid FEATURE_TYPE GeometryFilter_SimpleSolid  }    OUTPUT { BRepSolid FEATURE_TYPE GeometryFilter_BRepSolid  }    OUTPUT { Box FEATURE_TYPE GeometryFilter_Box  }    OUTPUT { CSGSolid FEATURE_TYPE GeometryFilter_CSGSolid  }    OUTPUT { Extrusion FEATURE_TYPE GeometryFilter_Extrusion  }    OUTPUT { Pipe FEATURE_TYPE GeometryFilter_Pipe  }    OUTPUT { Surface FEATURE_TYPE GeometryFilter_Surface  }    OUTPUT { CompositeSurface FEATURE_TYPE GeometryFilter_CompositeSurface  }    OUTPUT { SimpleSurface FEATURE_TYPE GeometryFilter_SimpleSurface  }    OUTPUT { Face FEATURE_TYPE GeometryFilter_Face  }    OUTPUT { Mesh FEATURE_TYPE GeometryFilter_Mesh  }    OUTPUT { RectangleFace FEATURE_TYPE GeometryFilter_RectangleFace  }    OUTPUT { TriangleFan FEATURE_TYPE GeometryFilter_TriangleFan  }    OUTPUT { TriangleStrip FEATURE_TYPE GeometryFilter_TriangleStrip  }    OUTPUT { Text FEATURE_TYPE GeometryFilter_Text  }    OUTPUT { VoxelGrid FEATURE_TYPE GeometryFilter_VoxelGrid  }
