FACTORY_DEF {*} StatisticsCalculatorFactory    FACTORY_NAME { StatisticsCalculator }    INPUT  FEATURE_TYPE GeometryFilter_Mesh    INPUT  FEATURE_TYPE GeometryFilter_Solid    INPUT  FEATURE_TYPE GeometryFilter_SimpleSolid    INPUT  FEATURE_TYPE GeometryFilter_BRepSolid    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    FEAT_STATS { fme_feature_type,NUMERIC_MODE,,,COUNT,,,,,,,,,, }    ADVANCED_MODE { NO }    CUMULATIVE_STATS {  }    CALCULATION_MODE { NUMERIC }    ATTR_ACCUM_MODE { None }    ATTRIBUTE_NAMES_AND_TYPES { fme_feature_type,varchar<openparen>50<closeparen> }    TREAT_INVALID_AS_NULL Yes    OUTPUT { SUMMARY FEATURE_TYPE StatisticsCalculator_SUMMARY        }
# -------------------------------------------------------------------------
INCLUDE [if { {ATTRIBUTES} == {ATTRIBUTES} } {                puts "MACRO FeatureMerger_REFERENCE_INFO ATTRIBUTES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {POLYGONS}} {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {AGGREGATES}} {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {POLYGONS}} {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_POLYS";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {AGGREGATES}} {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} && {<Unused>} == {LINESFROMPOINTS}} {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_LINES_FROM_POINTS";             }          elseif { {ATTRIBUTES} == {GEOM_BUILD} } {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_BUILD_AGGREGATES";             }          elseif { {ATTRIBUTES} == {GEOM_AND_ATTRS} } {                puts "MACRO FeatureMerger_REFERENCE_INFO GEOM_AND_ATTR_BUILD_AGGREGATES";             }          else {}; ]
FACTORY_DEF {*} ReferenceFactory    FACTORY_NAME { FeatureMerger }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT REFERENCER FEATURE_TYPE 0_ACAD_1_0_uXCUtW8OIRU=    INPUT REFERENCEE FEATURE_TYPE StatisticsCalculator_SUMMARY    REFERENCE_INFO { $(FeatureMerger_REFERENCE_INFO) }    REFERENCE_TABLE { 1 1 AUTO }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "REQUESTOR_IF_CONFLICT" }    IGNORE_NULLS { "No" }    HANDLE_NULL_MISSING_KEYS_LIKE_FME2013 { No }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MERGE_ATTRIBUTES Yes    MANAGE_FME_TYPE Yes    MODE COMPLETE    PROCESS_DUPLICATE_REFERENCEES { NO }    REFERENCEES_FIRST { No }    REJECT_INVALID_GEOM YES    CLEANING_TOLERANCE { <Unused> }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    COMPARE_WHITESPACE Yes    OUTPUT { COMPLETE FEATURE_TYPE FeatureMerger_MERGED         }    OUTPUT { INCOMPLETE FEATURE_TYPE FeatureMerger_UNMERGED_REQUESTOR         }    OUTPUT { REJECTED FEATURE_TYPE FeatureMerger_<REJECTED>         }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME FeatureMerger_<Rejected> INPUT FEATURE_TYPE FeatureMerger_<REJECTED>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, FeatureMerger<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Log<space>and<space>Troubleshoot<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { Tester }    INPUT  FEATURE_TYPE FeatureMerger_MERGED    INPUT  FEATURE_TYPE FeatureMerger_UNMERGED_REQUESTOR    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>fme_feature_type.total_count<closeparen>,Tester)" > 0 ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE Tester_PASSED         }    OUTPUT { FAILED FEATURE_TYPE Tester_FAILED         }
# -------------------------------------------------------------------------
FME_PYTHON_PATH "$(FME_MF_DIR)"
FACTORY_DEF {CONNECTED} CreationFactory    FACTORY_NAME { PythonCaller_Creator }    OUTPUT { FEATURE_TYPE PythonCaller_____CREATED______ }
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { PythonCaller }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT { FEATURE_TYPE PythonCaller_____CREATED______ }    INPUT  FEATURE_TYPE Tester_PASSED    SYMBOL_NAME { FeatureProcessor }    SOURCE_CODE { <quote><quote><quote><lf>DWG<solidus>DWF<space>to<space>GLB<space>+<space>GeoJSON<space>Pipeline<space>for<space>FME<space>PythonCaller<lf>=======================================================<lf>Combined<space>module<space>for<space>processing<space>DWG<solidus>DWF<space>files<space>into:<lf>-<space>GLB<space>3D<space>models<space><openparen>with<space>optional<space>rotation<space>and<space>compression<closeparen><lf>-<space>Plan<space>polygon<space>GeoJSON<space>for<space>Cesium<solidus>Origo<space>Globe<space>placement<lf>-<space>Metadata<space>JSON<space>for<space>positioning<lf><lf>This<space>script<space>works<space>in<space>TWO<space>modes:<lf>1.<space>FME<space>Geometry<space>Mode<space><openparen>RECOMMENDED<closeparen>:<space>FME<space>reads<space>DWG<solidus>DWF<space>and<space>passes<space>3D<space>geometry<space>features<lf>2.<space>External<space>Converter<space>Mode:<space>Uses<space>ODA<space>File<space>Converter<space>to<space>convert<space>DWG<space><u2192><space>OBJ<space><u2192><space>GLB<lf><lf>REQUIRED<space>PYTHON<space>PACKAGES<space><openparen>install<space>in<space>FME<space>Python<space>environment<closeparen>:<lf><space><space><space><space>pip<space>install<space>pyproj<space>trimesh<space>pygltflib<space>shapely<space>numpy<lf><lf>OPTIONAL<space>PACKAGES<space><openparen>for<space>better<space>polygon<space>generation<closeparen>:<lf><space><space><space><space>pip<space>install<space>concave-hull<space>scikit-learn<space>scipy<lf><lf>OPTIONAL<space>EXTERNAL<space>TOOLS:<lf><space><space><space><space>-<space>ODA<space>File<space>Converter<space><openparen>for<space>standalone<space>DWG<space>conversion<closeparen><space>-<space>https:<solidus><solidus>www.opendesign.com<solidus>guestfil