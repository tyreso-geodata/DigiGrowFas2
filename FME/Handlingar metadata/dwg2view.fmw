GUI OPTIONAL DYNAMIC_MULTI_SELECT_ENCODED ACAD_IN_RESOLVE_SELECTED_BLOCKS_ACAD_1 $[SourceDataset_ACAD_1],_READ_SCHEMA_OVERRIDE_MODE,BLOCK_NAMES,_FORMAT_OVERRIDE_,ACAD Explode Selected Blocks
