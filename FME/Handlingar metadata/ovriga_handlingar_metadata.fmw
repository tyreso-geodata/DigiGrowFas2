GUI OPTIONAL DISCLOSUREGROUP FILECOPY_OUT_FME_GROUP_NAMED2_FILECOPY_1 FILECOPY_OUT_OVERWRITE_FILE_FILECOPY_1%FILECOPY_OUT_FEATURE_TYPE_NAMES_AS_FOLDERS_FILECOPY_1%FILECOPY_OUT_FAIL_INVALID_DESTINATION_FILECOPY_1 Destination Parameters
# =====================================================================
