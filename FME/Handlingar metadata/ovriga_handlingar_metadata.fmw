rts<space>Bulk<space>mode<comma><lf><space><space><space><space><space><space><space><space>which<space>allows<space>for<space>significant<space>performance<space>gains<space>when<space>processing<space>large<space>numbers<space>of<space>features.<lf><space><space><space><space><space><space><space><space><quote><quote><quote><lf><space><space><space><space><space><space><space><space>return<space>support_type<space>==<space>fmeobjects.FME_SUPPORT_FEATURE_TABLE_SHIM<lf><lf><space><space><space><space>def<space>input<openparen>self<comma><space>feature:<space>fmeobjects.FMEFeature<closeparen>:<lf><space><space><space><space><space><space><space><space><quote><quote><quote>This<space>method<space>is<space>called<space>for<space>each<space>feature<space>which<space>enters<space>the<space>PythonCaller.<quote><quote><quote><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>#<space>Get<space>the<space>source<space>file<space>path<space>from<space>FME<space>macro<space>values<lf><space><space><space><space><space><space><space><space>source_file<space>=<space>fme.macroValues.get<openparen><apos>SOURCE_FILE<apos><comma><space><apos><apos><closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>if<space>source_file<space>and<space>os.path.exists<openparen>source_file<closeparen>:<lf><space><space><space><space><space><space><space><space><space><space><space><space>#<space>Get<space>file<space>size<space>in<space>bytes<lf><space><space><space><space><space><space><space><space><space><space><space><space>file_size<space>=<space>os.path.getsize<openparen>source_file<closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>file_size_bytes<apos><comma><space>file_size<closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space><space><space><space><space>#<space>Optional:<space>also<space>set<space>file<space>size<space>in<space>MB<space>for<space>convenience<lf><space><space><space><space><space><space><space><space><space><space><space><space>file_size_mb<space>=<space>file_size<space><solidus><space><openparen>1024<space>*<space>1024<closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>file_size_mb<apos><comma><space>round<openparen>file_size_mb<comma><space>2<closeparen><closeparen><lf><space><space><space><space><space><space><space><space>else:<lf><space><space><space><space><space><space><space><space><space><space><space><space>#<space>Handle<space>case<space>where<space>file<space>doesn<apos>t<space>exist<space>or<space>macro<space>is<space>empty<lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>file_size_bytes<apos><comma><space>-1<closeparen><lf><space><space><space><space><space><space><space><space><space><space><space><space>feature.setAttribute<openparen><apos>file_size_mb<apos><comma><space>-1<closeparen><lf><space><space><space><space><space><space><space><space><lf><space><space><space><space><space><space><space><space>self.pyoutput<openparen>feature<comma><space>output_tag=<quote>PYOUTPUT<quote><closeparen><lf><lf><space><space><space><space>def<space>close<openparen>self<closeparen>:<lf><space><space><space><space><space><space><space><space><quote><quote><quote>This<space>method<space>is<space>called<space>once<space>all<space>the<space>FME<space>Features<space>have<space>been<space>processed<space>from<space>input<openparen><closeparen>.<quote><quote><quote><lf><space><space><space><space><space><space><space><space>pass<lf><lf><space><space><space><space>def<space>process_group<openparen>self<closeparen>:<lf><space><space><space><space><space><s