          {
            "name": "osm",
            "tooltipText": "OpenStreetMap",
            "method": "LatLon",
            "url": "https://www.openstreetmap.org/#map=17/{{LAT}}/{{LON}}",
            "buttonImage": "img/png/Openstreetmap.png"
          },
          {
            "name": "googlestreet",
            "tooltipText": "Google street view",
